<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- ============================================================
       STAGE 4 — Cyberpsychosis mental state.
       Like Berserk (attacks everything in sight), but uses a custom
       state class that adds/removes the CyberPsychosisBoost hediff.
       ============================================================ -->
  <MentalStateDef ParentName="BaseMentalState">
    <defName>CyberPsychosis</defName>
    <stateClass>CyberPsycho.MentalState_CyberPsychosis</stateClass>
    <workerClass>MentalStateWorker</workerClass>
    <label>cyberpsychosis</label>
    <category>Aggro</category>
    <blockInteractionInitiationExcept>
      <li>Insult</li>
    </blockInteractionInitiationExcept>
    <blockRandomInteraction>true</blockRandomInteraction>
    <blockNormalThoughts>true</blockNormalThoughts>
    <nameColor>(0.2,0.85,0.95)</nameColor>
    <beginLetter>{0} has succumbed to cyberpsychosis.\n\nThe machines have taken over. [PAWN_pronoun] will attack anyone [PAWN_pronoun] sees, moving and striking far beyond human limits, and feeling no pain.</beginLetter>
    <beginLetterLabel>Cyberpsychosis</beginLetterLabel>
    <beginLetterDef>ThreatBig</beginLetterDef>
    <minTicksBeforeRecovery>25000</minTicksBeforeRecovery>
    <maxTicksBeforeRecovery>60000</maxTicksBeforeRecovery>
    <recoveryMtbDays>0.25</recoveryMtbDays>
    <recoveryMessage>{0}'s cyberpsychotic episode has ended.</recoveryMessage>
    <baseInspectLine>Mental state: Cyberpsychosis</baseInspectLine>
    <stateEffecter>Berserk</stateEffecter>
    <tale>MentalStateBerserk</tale>
    <recoverFromSleep>true</recoverFromSleep>
    <inCaravanCanDo>true</inCaravanCanDo>
  </MentalStateDef>

</Defs>
